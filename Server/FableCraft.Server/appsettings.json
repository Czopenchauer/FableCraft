{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Docker": {
    "SocketPath": "unix:///var/run/docker.sock",
    "UtilityImage": "alpine:latest"
  },
  "GraphService": {
    "EvictionTime": "00:10:00",
    "ImageName": "fablecraft-graph-rag-api:latest",
    "ContainerName": "graph-rag-api",
    "ContainerNamePrefix": "graph-rag-",
    "NetworkName": "fablecraft-network",
    "Port": 8111,
    "BasePort": 8111,
    "ContainerPort": 8111,
    "MaxConcurrentContainers": 10,
    "HealthEndpoint": "/health",
    "HealthCheckTimeoutSeconds": 60,
    "VisualizationPath": "./visualization",
    "DataStorePath": "./data-store",
    "ExportsPath": "./exports",
    "WorldbookVolumePrefix": "kg-worldbook-",
    "AdventureVolumePrefix": "kg-adventure-",
    "VolumeMountPath": "/app/knowledge-graph",
    "LogsPath": "./logs/graphrag"
  },
  "ImageGeneration": {
    "Enabled": true,
    "Provider": "SwarmUI",
    "ImageStoragePath": "./scene-images",
    "ImageStorageHostPath": null,
    "ComfyUI": {
      "BaseUrl": "http://localhost:8008",
      "GenerationTimeout": "00:05:00",
      "PollInterval": "00:00:02",
      "WorkflowPath": "./comfyui-workflows/scene-generation.json"
    },
    "SwarmUI": {
      "BaseUrl": "http://host.docker.internal:7801",
      "Model": "WAI-illustrious-SDXL_-_v17-0",
      "Width": 1536,
      "Height": 1536,
      "Steps": 20,
      "CfgScale": 5.5,
      "Sampler": "euler",
      "Seed": -1,
      "GenerationTimeout": "00:05:00",
      "PositiveAppendix": "masterpiece,best quality,amazing quality, nsfw, ",
      "NegativeAppendix": "bad quality,worst quality,worst detail,sketch,censor",
      "Loras": ["MoriiMee_Gothic_Niji_-_LoRA_Style_-_V1_Illustrious_Redux"],
      "LoraWeights": [1],
      "FaceRestorationPrompt": "highly detailed face, sharp eyes, realistic skin texture",
      "HandRestorationPrompt": "five fingers, anatomically correct hand, detailed fingers"
    }
  },
  "ProjectManagement": {
    "FilesPath": "./project-files",
    "FilesHostPath": null
  }
}